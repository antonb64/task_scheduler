{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/antonb64/task_scheduler/main/schemas/connectors-v1.schema.json",
  "title": "Task Scheduler Connector Bootstrap Configuration v1",
  "description": "Local coordinator bootstrap configuration for named HTTP sidecar artifact connectors. Connector configuration rejects unknown properties.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version"
  ],
  "properties": {
    "api_version": {
      "const": "scheduler/connectors/v1"
    },
    "connectors": {
      "type": "object",
      "default": {},
      "propertyNames": {
        "maxLength": 63,
        "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/connector"
      }
    }
  },
  "$defs": {
    "connector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_url"
      ],
      "properties": {
        "base_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://[^/?#][^?#]*$",
          "not": {
            "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://[^/?#]*@"
          },
          "description": "HTTP is accepted only for loopback hosts or when allow_insecure_http is true. User information, query strings, and fragments are rejected at runtime."
        },
        "bearer_token_env": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "\\S",
          "default": null,
          "description": "Name of the environment variable containing the bearer token; never put the token itself in this document."
        },
        "allowed_kinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "blueprint",
              "parameters"
            ]
          },
          "default": [
            "parameters"
          ]
        },
        "connect_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 18446744073709551615,
          "default": 5
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 18446744073709551615,
          "default": 20,
          "description": "The runtime additionally requires connect_timeout_seconds to be no greater than timeout_seconds."
        },
        "allow_insecure_http": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
