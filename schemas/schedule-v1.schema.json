{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/antonb64/task_scheduler/main/schemas/schedule-v1.schema.json",
  "title": "Task Scheduler Schedule v1",
  "description": "The ScheduleSpec accepted by the v1 management API. Unknown top-level properties are rejected to catch configuration typos.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "blueprint_ref",
    "parameters_ref"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "\\S"
    },
    "blueprint_ref": {
      "$ref": "#/$defs/artifact_ref"
    },
    "parameters_ref": {
      "$ref": "#/$defs/artifact_ref"
    },
    "parameter_collection": {
      "anyOf": [
        {
          "$ref": "#/$defs/parameter_collection"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional per-trigger collection expansion. When absent, the trigger creates one ordinary run."
    },
    "observability": {
      "$ref": "#/$defs/observability",
      "default": {},
      "description": "Per-schedule operational completion objective. Omitted values are resolved and persisted from cluster defaults when the schedule is created or updated."
    },
    "required_labels": {
      "$ref": "#/$defs/labels",
      "default": {}
    },
    "cron": {
      "anyOf": [
        {
          "$ref": "#/$defs/cron"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "webhook_enabled": {
      "type": "boolean",
      "default": false
    },
    "enabled": {
      "type": "boolean",
      "default": true
    }
  },
  "$defs": {
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri",
          "pattern": "^[A-Za-z][A-Za-z0-9+.-]*:"
        }
      }
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "completion_deadline_seconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum time from scheduled_at until successful completion before the trigger is overdue."
        }
      }
    },
    "parameter_collection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref"
      ],
      "properties": {
        "source_ref": {
          "$ref": "#/$defs/artifact_ref"
        },
        "page_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 500
        },
        "max_items": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "default": 10000
        },
        "max_active_runs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 32
        },
        "poison_distinct_nodes": {
          "type": "integer",
          "minimum": 2,
          "maximum": 32,
          "default": 2
        }
      }
    },
    "cron": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expression",
        "timezone"
      ],
      "properties": {
        "expression": {
          "type": "string",
          "pattern": "\\S"
        },
        "timezone": {
          "type": "string",
          "pattern": "\\S"
        }
      },
      "description": "The coordinator additionally parses expression with the Rust cron grammar and timezone as an IANA timezone."
    }
  }
}
